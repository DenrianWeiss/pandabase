# Pandabase Environment Configuration

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=pandabase
DB_PASSWORD=pandabase
DB_NAME=pandabase
DB_SSL_MODE=disable

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# File Storage
STORAGE_TYPE=filesystem
STORAGE_DATA_PATH=./data/files
STORAGE_MAX_FILE_SIZE=100

# Server
SERVER_PORT=8080
SERVER_HOST=0.0.0.0

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Embedding
# API endpoint - supports any OpenAI-compatible API
EMBEDDING_API_URL=https://api.openai.com/v1

# Model name - depends on your API provider
EMBEDDING_MODEL=text-embedding-ada-002

# Embedding dimensions - must match your model
EMBEDDING_DIMENSIONS=1536

# Multimodal mode (Doubao only) - set to true to enable image+text embedding
EMBEDDING_ENABLE_MULTIMODAL=false

# API key
EMBEDDING_API_KEY=
